---
import ScrollReveal from "@/components/common/ScrollReveal.astro";

const lang = Astro.url.pathname.startsWith("/en") ? "en" : "zh";

const partnerDetails = [
  { name: "ByteDance", color: "from-[#1A5FFF] to-[#5B4BEA]", abbr: "字节" },
  { name: "Alibaba", color: "from-[#FF6A00] to-[#EE0979]", abbr: "阿里" },
  { name: "MiraclePlus", color: "from-[#00BFA5] to-[#1A5FFF]", abbr: "奇绩" },
  { name: "Datawhale", color: "from-[#5B4BEA] to-[#8B5CF6]", abbr: "DW" },
  { name: "ZhenFund", color: "from-[#EE0979] to-[#FF6A00]", abbr: "真格" },
  { name: "Momenta", color: "from-[#00BFA5] to-[#5B4BEA]", abbr: "MT" },
  { name: "Tencent", color: "from-[#1A5FFF] to-[#00BFA5]", abbr: "腾讯" },
];
---

<section class="border-border-subtle scene-ribbon border-t py-20">
  <div class="mx-auto max-w-5xl px-6">
    <ScrollReveal>
      <p
        class="text-text-muted mb-2 text-center text-xs font-semibold tracking-[0.2em] uppercase"
      >
        {lang === "en" ? "Trusted by Industry Leaders" : "合作企业 & 社区"}
      </p>
    </ScrollReveal>

    <div
      class="scene-tableau-in mt-10 flex flex-wrap items-center justify-center gap-3"
    >
      {
        partnerDetails.map((p, i) => (
          <ScrollReveal class={`delay-${i * 100}`}>
            <div class="glass glass-hover flex cursor-default items-center gap-3 rounded-xl px-5 py-3">
              <div
                class={`flex h-8 w-8 items-center justify-center rounded-lg bg-gradient-to-br ${p.color} text-xs font-bold text-white shadow-sm`}
              >
                {p.abbr}
              </div>
              <span class="text-text-primary text-sm font-medium">
                {p.name}
              </span>
            </div>
          </ScrollReveal>
        ))
      }
    </div>
  </div>
</section>
