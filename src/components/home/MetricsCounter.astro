---
import { METRICS } from "@/lib/constants";
import ScrollReveal from "@/components/common/ScrollReveal.astro";

const lang = Astro.url.pathname.startsWith("/en") ? "en" : "zh";
---

<section class="bg-gemini-surface scene-ribbon py-20" data-section-theme="gold">
  <div class="mx-auto max-w-[var(--content-max)] px-6">
    <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
      {
        METRICS.map((metric, i) => (
          <ScrollReveal class="text-center">
            <div
              class="scene-montage-in text-4xl font-extrabold tracking-tight md:text-5xl"
              style={`animation-delay: ${i * 100}ms`}
            >
              <span
                class="counter text-gradient"
                data-target={metric.value}
                data-suffix={metric.suffix}
              >
                0
              </span>
            </div>
            <p
              class="scene-montage-in text-text-secondary mt-2 text-sm"
              style={`animation-delay: ${i * 100 + 150}ms`}
            >
              {lang === "en" ? metric.labelEn : metric.label}
            </p>
          </ScrollReveal>
        ))
      }
    </div>
  </div>
</section>

<script>
  function animateCounters() {
    document.querySelectorAll<HTMLElement>(".counter").forEach((el) => {
      const target = parseInt(el.dataset.target || "0");
      const suffix = el.dataset.suffix || "";
      const duration = 2000;
      const start = performance.now();

      function update(now: number) {
        const elapsed = now - start;
        const progress = Math.min(elapsed / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        const current = Math.floor(eased * target);
        el.textContent = `${current}${suffix}`;
        if (progress < 1) requestAnimationFrame(update);
      }

      requestAnimationFrame(update);
    });
  }

  const section = document.currentScript?.closest("section");
  const obs = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          animateCounters();
          obs.disconnect();
        }
      });
    },
    { threshold: 0.5 },
  );
  if (section) obs.observe(section);
</script>
