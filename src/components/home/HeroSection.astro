---
import { SITE } from "@/lib/constants";

const lang = Astro.url.pathname.startsWith("/en") ? "en" : "zh";
const title = lang === "en" ? SITE.nameEn : SITE.name;
const titleChars = [...title];
---

<section
  class="hero bg-gemini-bg relative flex min-h-screen items-center justify-center overflow-hidden"
  data-section-theme="dark"
  id="hero"
>
  <!-- Ambient light orbs (with parallax layers) -->
  <div class="absolute inset-0 z-0 overflow-hidden">
    <div
      class="hero-orb animate-float-slow bg-spectrum-gold/12 absolute -top-32 left-[10%] h-[500px] w-[500px] rounded-full blur-[120px]"
      style="--parallax: -0.06"
    >
    </div>
    <div
      class="hero-orb animate-float-slower bg-spectrum-orange/8 absolute top-[20%] right-[5%] h-[600px] w-[600px] rounded-full blur-[140px]"
      style="--parallax: -0.03"
    >
    </div>
    <div
      class="hero-orb animate-float bg-spectrum-rose/6 absolute -bottom-32 left-[30%] h-[400px] w-[400px] rounded-full blur-[100px]"
      style="--parallax: -0.09"
    >
    </div>
    <div
      class="hero-orb animate-float-slow bg-spectrum-gold/5 absolute top-[50%] left-[60%] h-[300px] w-[300px] rounded-full blur-[80px]"
      style="--parallax: -0.05"
    >
    </div>
  </div>

  <!-- Spotlight — the projector beam from darkness -->
  <div
    class="spotlight pointer-events-none absolute inset-0 z-[2]"
    aria-hidden="true"
  >
  </div>

  <!-- Content -->
  <div
    class="hero-content relative z-10 mx-auto max-w-4xl px-6 py-32 text-center"
  >
    <!-- Spark Brand Icon -->
    <div class="scroll-reveal mb-12 flex justify-center">
      <div
        class="spark-frame animate-pulse-glow relative flex h-24 w-24 items-center justify-center rounded-full"
      >
        <svg
          width="52"
          height="52"
          viewBox="0 0 64 64"
          fill="none"
          class="spark-icon relative z-10"
        >
          <path
            d="M32 4L35 21L39 13L37 26L44 19L38 29L50 26L40 33L48 38L36 35L42 46L32 38L25 47L28 36L20 42L26 31L18 33L27 27L20 21L30 26L26 15L32 24L34 7L32 4Z"
            fill="url(#hero-spark)"
          >
          </path>
          <defs>
            <linearGradient
              id="hero-spark"
              x1="8"
              y1="8"
              x2="56"
              y2="56"
              gradientUnits="userSpaceOnUse"
            >
              <stop stop-color="#C88810"></stop>
              <stop offset="0.4" stop-color="#F0D060"></stop>
              <stop offset="1" stop-color="#D43D52"></stop>
            </linearGradient>
          </defs>
        </svg>
      </div>
    </div>

    <!-- Badge -->
    <div
      class="scroll-reveal border-accent/20 bg-accent/5 mb-10 inline-flex items-center gap-2 rounded-full border px-5 py-2 text-sm backdrop-blur-sm"
    >
      <span class="bg-accent h-1.5 w-1.5 animate-pulse rounded-full"></span>
      <span class="text-accent font-medium tracking-wide">
        {lang === "en" ? "A USTC Student Organization" : "USTC 青年学生组织"}
      </span>
    </div>

    <!-- Decorative top rule — classical gold line with diamond -->
    <div class="scroll-reveal ornamental-rule mb-8"></div>

    <!-- Main Title — Luxury Art Text -->
    <h1 class="scroll-reveal luxury-title mb-6" aria-label={title}>
      {
        titleChars.map((char, i) => (
          <span class="title-char" style={`animation-delay: ${i * 0.12}s`}>
            {char === " " ? " " : char}
          </span>
        ))
      }
    </h1>

    <!-- Decorative bottom rule — mirrors the top -->
    <div class="scroll-reveal ornamental-rule mb-8"></div>

    <!-- Subtitle -->
    <p
      class="scroll-reveal text-text-secondary mx-auto mb-14 max-w-xl text-lg leading-relaxed tracking-wide md:text-xl"
    >
      {lang === "en" ? SITE.descriptionEn : SITE.description}
    </p>

    <!-- CTAs -->
    <div
      class="scroll-reveal flex flex-col items-center justify-center gap-4 sm:flex-row"
    >
      <a
        href={lang === "en" ? "/en/about" : "/about"}
        class="btn-primary btn-shimmer btn-halo group inline-flex items-center gap-2 rounded-full px-8 py-3.5 text-sm font-semibold"
      >
        {lang === "en" ? "Learn More" : "了解更多"}
        <span
          class="arrow inline-block transition-all duration-700 ease-[cubic-bezier(0.22,0.61,0.36,1)] group-hover:translate-x-1"
          >&rarr;</span
        >
      </a>
      <a
        href={lang === "en" ? "/en/join" : "/join"}
        class="btn-secondary btn-shimmer btn-halo inline-flex items-center gap-2 rounded-full px-8 py-3.5 text-sm font-semibold"
      >
        {lang === "en" ? "Join Us" : "加入我们"}
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 z-10 -translate-x-1/2">
    <a
      href="#content-start"
      class="text-text-muted hover:text-accent flex flex-col items-center gap-2 transition-colors duration-500"
    >
      <span class="text-[10px] tracking-[0.25em] uppercase">
        {lang === "en" ? "Scroll" : "向下滚动"}
      </span>
      <svg
        class="scroll-arrow h-4 w-4"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M12 5v14M19 12l-7 7-7-7"></path>
      </svg>
    </a>
  </div>
</section>

<style>
  /* ═══════════════════════════════════════════
     Luxury Art-Text Title
     ═══════════════════════════════════════════ */

  .luxury-title {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 7vw, 6.5rem);
    font-weight: 900;
    line-height: 1.08;
    letter-spacing: 0.03em;

    /* Metallic gradient: gold → bright gold → rose → copper */
    background: linear-gradient(
      135deg,
      #c88810 0%,
      #f0d060 20%,
      #e8a820 35%,
      #d43d52 55%,
      #e05535 70%,
      #c88810 85%,
      #f0d060 100%
    );
    background-size: 300% 300%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;

    animation: luxury-shimmer 5s ease-in-out infinite;

    /* Stacked filter for micro depth */
    filter: drop-shadow(0 2px 4px rgba(200, 136, 16, 0.2));
  }

  /* Shimmer sweep — a bright highlight travels across the metallic text */
  @keyframes luxury-shimmer {
    0% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0% 50%;
    }
  }

  /* ═══════════════════════════════════════════
     Spark Icon Container
     ═══════════════════════════════════════════ */

  .spark-frame {
    background: radial-gradient(
      circle at center,
      rgba(200, 136, 16, 0.12) 0%,
      transparent 70%
    );
  }

  .spark-icon {
    animation: spark-rotate 20s linear infinite;
    transform-origin: center;
  }

  @keyframes spark-rotate {
    to {
      transform: rotate(360deg);
    }
  }

  /* ═══════════════════════════════════════════
     CTA Buttons — silky, barely-there feel
     ═══════════════════════════════════════════ */

  .btn-primary {
    position: relative;
    color: var(--color-accent);
    background: rgba(200, 136, 16, 0.06);
    border: 1px solid rgba(200, 136, 16, 0.18);
    transition: all 0.7s cubic-bezier(0.22, 0.61, 0.36, 1);
  }

  .btn-primary:hover {
    background: rgba(200, 136, 16, 0.12);
    border-color: rgba(200, 136, 16, 0.35);
    box-shadow:
      0 0 32px rgba(200, 136, 16, 0.08),
      inset 0 0 0 1px rgba(200, 136, 16, 0.04);
  }

  .btn-primary .arrow {
    opacity: 0.6;
  }

  .btn-primary:hover .arrow {
    opacity: 1;
  }

  .btn-secondary {
    color: var(--color-text-primary);
    background: rgba(255, 255, 255, 0.5);
    border: 1px solid rgba(0, 0, 0, 0.05);
    transition: all 0.7s cubic-bezier(0.22, 0.61, 0.36, 1);
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.85);
    border-color: rgba(200, 136, 16, 0.15);
    box-shadow: 0 0 24px rgba(0, 0, 0, 0.03);
  }

  @keyframes btn-shimmer {
    0%,
    100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }

  /* ═══════════════════════════════════════════
     Scroll Arrow
     ═══════════════════════════════════════════ */

  .scroll-arrow {
    animation: scroll-bounce 2s ease-in-out infinite;
  }

  @keyframes scroll-bounce {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(6px);
    }
  }

  /* ═══════════════════════════════════════════
     Hero Depth Exit — content recedes as user scrolls past.
     CSS-only, progressive enhancement.
     ═══════════════════════════════════════════ */

  @supports (animation-timeline: view()) {
    .hero-content {
      animation: hero-exit linear both;
      animation-timeline: view();
      animation-range: exit 0% exit 100%;
      transform-origin: center top;
    }
  }

  @keyframes hero-exit {
    to {
      scale: 0.96;
      opacity: 0.15;
      filter: blur(2px);
    }
  }

  /* ═══════════════════════════════════════════
     Motion Respect
     ═══════════════════════════════════════════ */

  @media (prefers-reduced-motion: reduce) {
    .luxury-title,
    .btn-primary,
    .spark-icon,
    .scroll-arrow,
    .hero-content {
      animation: none !important;
    }
  }

  /* ═══════════════════════════════════════════
     追光聚光灯 — 从中心扩散的暖光，跟随鼠标并随滚动 bloom
     ═══════════════════════════════════════════ */

  .spotlight {
    background: radial-gradient(
      ellipse 60% 50% at var(--cursor-x, 50%) var(--cursor-y, 40%),
      rgba(200, 136, 16, 0.15) 0%,
      rgba(200, 136, 16, 0.05) 30%,
      rgba(224, 85, 53, 0.03) 50%,
      transparent 70%
    );
  }

  @supports (animation-timeline: view()) {
    .spotlight {
      animation: spotlight-bloom 2s cubic-bezier(0.22, 0.61, 0.36, 1) both;
      animation-timeline: view();
      animation-range: cover 0% cover 50%;
    }
  }

  @keyframes spotlight-bloom {
    from {
      opacity: 0.3;
      filter: brightness(0.4);
    }
    to {
      opacity: 1;
      filter: brightness(1);
    }
  }

  /* ═══════════════════════════════════════════
     Scroll Parallax Orbs
     Each orb translates at its own speed as you scroll.
     ═══════════════════════════════════════════ */

  .hero-orb {
    will-change: transform;
  }
</style>

<script>
  let cleanupHero: (() => void) | null = null;

  function setupHero() {
    cleanupHero?.();

    const hero = document.getElementById("hero");
    if (!hero) return;

    // 微延迟后开始字符浮现（等待暗场稳定）
    requestAnimationFrame(() => {
      hero.classList.add("reveal-started");
    });

    const cleanups: (() => void)[] = [];

    // Spotlight cursor tracking — uses latest-event pattern to avoid lag
    const spotlight = hero.querySelector<HTMLElement>(".spotlight");
    if (spotlight) {
      let ticking = false;
      let latest: MouseEvent | null = null;

      const onMouseMove = (e: MouseEvent) => {
        latest = e;
        if (!ticking) {
          requestAnimationFrame(() => {
            if (!latest) return;
            const rect = hero.getBoundingClientRect();
            spotlight.style.setProperty(
              "--cursor-x",
              `${((latest.clientX - rect.left) / rect.width) * 100}%`,
            );
            spotlight.style.setProperty(
              "--cursor-y",
              `${((latest.clientY - rect.top) / rect.height) * 100}%`,
            );
            // Warmer, larger glow over interactive elements
            const target = latest.target as HTMLElement;
            const isInteractive = target?.closest("a, button, [data-tilt]");
            spotlight.style.opacity = isInteractive ? "1" : "0.6";
            ticking = false;
            latest = null;
          });
          ticking = true;
        }
      };

      hero.addEventListener("mousemove", onMouseMove, { passive: true });
      cleanups.push(() => hero.removeEventListener("mousemove", onMouseMove));
    }

    // Scroll parallax orbs
    const orbs = document.querySelectorAll<HTMLElement>(".hero-orb");
    if (orbs.length) {
      let scrollTicking = false;

      const onScroll = () => {
        if (!scrollTicking) {
          requestAnimationFrame(() => {
            const scrollY = window.scrollY;
            orbs.forEach((orb) => {
              const rate =
                parseFloat(orb.style.getPropertyValue("--parallax")) || -0.05;
              orb.style.transform = `translateY(${scrollY * rate}px)`;
            });
            scrollTicking = false;
          });
          scrollTicking = true;
        }
      };

      window.addEventListener("scroll", onScroll, { passive: true });
      cleanups.push(() => window.removeEventListener("scroll", onScroll));
    }

    cleanupHero = () => {
      cleanups.forEach((fn) => fn());
      cleanups.length = 0;
    };
  }

  setupHero();
  document.addEventListener("astro:after-swap", setupHero);
  document.addEventListener("astro:before-swap", () => cleanupHero?.());

  // Scroll-focus: subtle dim while scrolling, sharpen on stop
  let scrollTimer: ReturnType<typeof setTimeout>;
  window.addEventListener(
    "scroll",
    () => {
      document.body.classList.add("scrolling");
      clearTimeout(scrollTimer);
      scrollTimer = setTimeout(() => {
        document.body.classList.remove("scrolling");
      }, 150);
    },
    { passive: true },
  );
</script>
