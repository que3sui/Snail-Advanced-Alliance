---
import { NAV_ITEMS, SITE } from "@/lib/constants";
import LanguageSwitch from "@/components/common/LanguageSwitch.astro";

const currentPath = Astro.url.pathname;
const lang = currentPath.startsWith("/en") ? "en" : "zh";
---

<header
  class="header"
  id="header"
  transition:name="header"
  transition:animate="fade"
>
  <nav
    class="mx-auto flex max-w-[var(--content-max)] items-center justify-between px-6 py-3"
  >
    <!-- Logo -->
    <a
      href={lang === "en" ? "/en" : "/"}
      class="flex items-center gap-3 text-lg font-semibold no-underline"
    >
      <!-- Spark icon -->
      <span class="relative flex h-9 w-9 items-center justify-center">
        <span
          class="animate-pulse-glow absolute inset-0 rounded-full opacity-60"
        >
        </span>
        <svg
          width="28"
          height="28"
          viewBox="0 0 32 32"
          fill="none"
          class="relative z-10"
        >
          <path
            d="M16 2L18.5 11.5L22 6L21 14.5L27 11L22.5 17L30 16.5L23 19.5L29 23L22 22L26 28L19.5 23L20 30.5L16.5 24L14 31L14.5 23L10 30L13 22.5L7 28L12.5 21L5 23.5L13 19L6 16L14.5 17.5L9 13L16.5 16L13 9.5L18 14L16 2Z"
            fill="url(#spark-gradient)"></path>
          <defs>
            <linearGradient
              id="spark-gradient"
              x1="4"
              y1="4"
              x2="30"
              y2="30"
              gradientUnits="userSpaceOnUse"
            >
              <stop stop-color="#C88810"></stop>
              <stop offset="0.5" stop-color="#E05535"></stop>
              <stop offset="1" stop-color="#D43D52"></stop>
            </linearGradient>
          </defs>
        </svg>
      </span>
      <span class="text-text-primary hidden sm:inline">
        {lang === "en" ? SITE.nameEn : SITE.name}
      </span>
    </a>

    <!-- Desktop Nav -->
    <ul class="hidden items-center gap-1 md:flex">
      {
        NAV_ITEMS.map((item) => {
          const href = lang === "en" ? `/en${item.href}` : item.href;
          const isActive =
            currentPath === href ||
            (item.href !== "/about" && currentPath.startsWith(item.href));
          return (
            <li>
              <a
                href={href}
                class={`rounded-full px-4 py-2 text-sm font-medium transition-all duration-300 ${
                  isActive
                    ? "bg-accent/15 text-accent"
                    : "text-text-secondary hover:text-text-primary hover:bg-gemini-hover/50"
                }`}
              >
                {lang === "en" ? item.en : item.zh}
              </a>
            </li>
          );
        })
      }
    </ul>

    <div class="flex items-center gap-3">
      <LanguageSwitch lang={lang} currentPath={currentPath} />

      <!-- Search button (triggers Pagefind modal) -->
      <button
        id="search-trigger"
        class="text-text-secondary hover:bg-gemini-hover/50 inline-flex cursor-pointer items-center justify-center rounded-full p-2 transition-colors"
        aria-label={lang === "en" ? "Search" : "搜索"}
        type="button"
      >
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        >
          <circle cx="11" cy="11" r="8"></circle>
          <path d="M21 21l-4.35-4.35"></path>
        </svg>
      </button>

      <!-- CTA pill -->
      <a
        href={lang === "en" ? "/en/join" : "/join"}
        class="border-accent/20 bg-accent/5 text-accent hover:border-accent/40 hover:bg-accent/10 hidden rounded-full border px-5 py-2 text-sm font-medium transition-all duration-700 ease-[cubic-bezier(0.22,0.61,0.36,1)] sm:inline-block"
      >
        {lang === "en" ? "Join Us" : "加入我们"}
      </a>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="text-text-secondary hover:bg-gemini-hover/50 inline-flex items-center justify-center rounded-full p-2 transition-colors md:hidden"
        aria-label={lang === "en" ? "Toggle menu" : "切换菜单"}
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        >
          <path d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="glass border-gemini-border mx-4 mt-2 hidden rounded-2xl border-t md:hidden"
  >
    <ul class="flex flex-col gap-1 px-4 py-4">
      {
        NAV_ITEMS.map((item) => {
          const href = lang === "en" ? `/en${item.href}` : item.href;
          return (
            <li>
              <a
                href={href}
                class="text-text-secondary hover:text-text-primary hover:bg-gemini-hover/50 block rounded-xl px-4 py-3 text-sm font-medium transition-colors"
              >
                {lang === "en" ? item.en : item.zh}
              </a>
            </li>
          );
        })
      }
    </ul>
  </div>
</header>

<script>
  const header = document.getElementById("header")!;
  const menuBtn = document.getElementById("mobile-menu-btn")!;
  const mobileMenu = document.getElementById("mobile-menu")!;

  window.addEventListener("scroll", () => {
    header.classList.toggle("scrolled", window.scrollY > 10);
  });

  menuBtn.addEventListener("click", () => {
    const open = !mobileMenu.classList.toggle("hidden");
    menuBtn.setAttribute("aria-expanded", String(open));
  });

  // Wire search button to Pagefind modal
  const searchBtn = document.getElementById("search-trigger");
  if (searchBtn) {
    searchBtn.addEventListener("click", () => {
      const modal = document.querySelector("pagefind-modal");
      if (modal && modal.openModal) {
        modal.openModal();
      }
    });
  }
</script>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    transition:
      background-color 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      backdrop-filter 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    background-color: transparent;
  }

  .header.scrolled {
    background-color: rgba(255, 251, 245, 0.8);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.06);
  }
</style>
