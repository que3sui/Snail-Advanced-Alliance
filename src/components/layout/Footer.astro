---
import { FOOTER_LINKS, SITE } from "@/lib/constants";

const lang = Astro.url.pathname.startsWith("/en") ? "en" : "zh";
---

<footer class="bg-primary-900 text-text-inverse">
  <div class="mx-auto max-w-[var(--content-max)] px-6 py-16">
    <div class="grid gap-12 md:grid-cols-4">
      <!-- Brand -->
      <div class="md:col-span-1">
        <a
          href={lang === "en" ? "/en" : "/"}
          class="mb-4 inline-block text-xl font-bold no-underline"
        >
          <span
            class="bg-primary-500 inline-block h-10 w-10 rounded-lg text-center text-lg leading-10 text-white"
          >
            进
          </span>
          <span class="ml-3">
            {lang === "en" ? SITE.nameEn : SITE.name}
          </span>
        </a>
        <p class="text-text-muted mt-4 text-sm">
          {lang === "en" ? SITE.descriptionEn : SITE.description}
        </p>
        <p class="text-text-muted mt-2 text-xs">
          {lang === "en" ? SITE.affiliationEn : SITE.affiliation}
        </p>
      </div>

      <!-- Link groups -->
      {
        FOOTER_LINKS.map((group) => (
          <div>
            <h4 class="text-primary-200 mb-4 text-sm font-semibold tracking-wider uppercase">
              {lang === "en" ? group.groupEn : group.group}
            </h4>
            <ul class="space-y-2">
              {group.items.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class="text-text-muted text-sm transition-colors hover:text-white"
                    target={item.href.startsWith("http") ? "_blank" : undefined}
                    rel={
                      item.href.startsWith("http")
                        ? "noopener noreferrer"
                        : undefined
                    }
                  >
                    {lang === "en" ? item.en : item.zh}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <!-- Bottom bar -->
    <div class="border-primary-700 mt-12 border-t pt-8">
      <div
        class="text-text-muted flex flex-col items-center justify-between gap-4 text-xs md:flex-row"
      >
        <p>
          &copy; {new Date().getFullYear()}
          {lang === "en" ? SITE.nameEn : SITE.name}. All rights reserved.
        </p>
        <div class="flex items-center gap-4">
          <span>QQ 群: {SITE.qqGroup}</span>
          <span>公众号: {SITE.wechat}</span>
          <a
            href="https://beian.miit.gov.cn/"
            target="_blank"
            rel="noopener noreferrer"
            class="transition-colors hover:text-white"
          >
            皖ICP备XXXXXXXX号
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
