---
import "@/styles/global.css";
import SEO from "@/components/common/SEO.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import BackToTop from "@/components/common/BackToTop.astro";

export interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description, image } = Astro.props;
const lang = Astro.url.pathname.startsWith("/en") ? "en" : "zh";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <SEO title={title} description={description} image={image} lang={lang} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Noto+Sans+SC:wght@400;500;700&display=swap"
    />
    <link href="/pagefind/pagefind-component-ui.css" rel="stylesheet" />
  </head>
  <body
    class="bg-gemini-bg text-text-primary relative min-h-screen antialiased"
  >
    <!-- Scroll progress thread — 1px gold line at top -->
    <div class="scroll-progress" aria-hidden="true"></div>

    <a
      href="#main-content"
      class="focus:bg-primary-500 sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:rounded-lg focus:px-4 focus:py-2 focus:text-white focus:shadow-lg"
    >
      {lang === "en" ? "Skip to content" : "跳转到内容"}
    </a>
    <Header />
    <main id="main-content" transition:name="main" transition:animate="slide">
      <slot />
    </main>
    <Footer />
    <BackToTop />

    <!-- Global search modal -->
    <pagefind-modal></pagefind-modal>
  </body>
</html>

<script is:inline src="/pagefind/pagefind-component-ui.js"></script>
<script is:inline>
  // Scroll reveal observer
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("revealed");
        }
      });
    },
    { threshold: 0.1, rootMargin: "0px 0px -50px 0px" },
  );

  document
    .querySelectorAll(".scroll-reveal")
    .forEach((el) => observer.observe(el));

  // Stagger reveal observer
  const staggerObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("stagger-revealed");
        }
      });
    },
    { threshold: 0.08, rootMargin: "0px 0px -40px 0px" },
  );

  document
    .querySelectorAll(".stagger-reveal")
    .forEach((el) => staggerObserver.observe(el));

  // Section ambient glow shift — watch themed sections and shift body gradient
  const glowObserver = new IntersectionObserver(
    (entries) => {
      // Find the most visible section and apply its theme
      let best = null;
      let bestRatio = 0;
      entries.forEach((entry) => {
        if (entry.isIntersecting && entry.intersectionRatio > bestRatio) {
          bestRatio = entry.intersectionRatio;
          best = entry.target;
        }
        // Remove stale entries
        if (!entry.isIntersecting && entry.target === best) {
          best = null;
          bestRatio = 0;
        }
      });
      // Re-scan all visible entries to find the best
      entries.forEach((entry) => {
        if (entry.isIntersecting && entry.intersectionRatio > bestRatio) {
          bestRatio = entry.intersectionRatio;
          best = entry.target;
        }
      });
      if (best) {
        const theme = best.dataset.sectionTheme;
        if (theme) {
          document.body.dataset.sectionTheme = theme;
        }
      }
    },
    { threshold: [0, 0.3, 0.6] },
  );

  document
    .querySelectorAll("[data-section-theme]")
    .forEach((el) => glowObserver.observe(el));
</script>

<style is:global>
  /* Pagefind Component UI — warm light theme overrides */
  :root {
    --pf-text: #1a1714;
    --pf-text-secondary: #5c5548;
    --pf-text-muted: #8a8276;
    --pf-background: #fffbf5;
    --pf-border: rgba(0, 0, 0, 0.06);
    --pf-border-focus: rgba(200, 136, 16, 0.35);
    --pf-skeleton: #f5ede0;
    --pf-primary: #c88810;
    --pf-radius: 12px;
  }
</style>
