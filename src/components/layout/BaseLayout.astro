---
import "@/styles/global.css";
import SEO from "@/components/common/SEO.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import BackToTop from "@/components/common/BackToTop.astro";

export interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description, image } = Astro.props;
const lang = Astro.url.pathname.startsWith("/en") ? "en" : "zh";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <SEO title={title} description={description} image={image} lang={lang} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Noto+Sans+SC:wght@400;500;700&display=swap"
    />
    <link href="/pagefind/pagefind-component-ui.css" rel="stylesheet" />
  </head>
  <body
    class="bg-gemini-bg text-text-primary relative min-h-screen antialiased"
  >
    <!-- Scroll progress thread — 1px gold line at top -->
    <div class="scroll-progress" aria-hidden="true"></div>

    <a
      href="#main-content"
      class="focus:bg-primary-500 sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:rounded-lg focus:px-4 focus:py-2 focus:text-white focus:shadow-lg"
    >
      {lang === "en" ? "Skip to content" : "跳转到内容"}
    </a>
    <Header />
    <main id="main-content" transition:name="main">
      <slot />
    </main>
    <Footer />
    <BackToTop />

    <!-- Global search modal -->
    <pagefind-modal></pagefind-modal>
  </body>
</html>

<script is:inline src="/pagefind/pagefind-component-ui.js"></script>
<script is:inline>
  var _scrollObserver = null;
  var _staggerObserver = null;

  function setupScrollReveal() {
    if (_scrollObserver) _scrollObserver.disconnect();
    if (_staggerObserver) _staggerObserver.disconnect();

    _scrollObserver = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add("revealed");
          }
        });
      },
      { threshold: 0.1, rootMargin: "0px 0px -50px 0px" },
    );

    document
      .querySelectorAll(".scroll-reveal:not(.revealed)")
      .forEach(function (el) {
        _scrollObserver.observe(el);
      });

    _staggerObserver = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add("stagger-revealed");
          }
        });
      },
      { threshold: 0.08, rootMargin: "0px 0px -40px 0px" },
    );

    document
      .querySelectorAll(".stagger-reveal:not(.stagger-revealed)")
      .forEach(function (el) {
        _staggerObserver.observe(el);
      });
  }

  var _themeScrollHandler = null;

  function setupSectionTheme() {
    var sections = document.querySelectorAll("[data-section-theme]");
    if (!sections.length) return;

    if (_themeScrollHandler) {
      window.removeEventListener("scroll", _themeScrollHandler);
    }

    var ticking = false;
    _themeScrollHandler = function () {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(function () {
        var best = null;
        var bestRatio = 0;
        var vh = window.innerHeight;
        sections.forEach(function (el) {
          var rect = el.getBoundingClientRect();
          var visibleTop = Math.max(0, rect.top);
          var visibleBottom = Math.min(vh, rect.bottom);
          var visibleHeight = Math.max(0, visibleBottom - visibleTop);
          var ratio = visibleHeight / rect.height;
          if (ratio > bestRatio) {
            bestRatio = ratio;
            best = el;
          }
        });
        if (best) {
          document.body.dataset.sectionTheme = best.dataset.sectionTheme || "";
        }
        ticking = false;
      });
    };

    window.addEventListener("scroll", _themeScrollHandler, { passive: true });
    _themeScrollHandler();
  }

  setupScrollReveal();
  setupSectionTheme();

  document.addEventListener("astro:before-swap", function () {
    if (_scrollObserver) _scrollObserver.disconnect();
    if (_staggerObserver) _staggerObserver.disconnect();
    if (_themeScrollHandler) {
      window.removeEventListener("scroll", _themeScrollHandler);
    }
  });

  document.addEventListener("astro:after-swap", function () {
    setupScrollReveal();
    setupSectionTheme();
  });
</script>

<style is:global>
  /* Pagefind Component UI — warm light theme overrides */
  :root {
    --pf-text: #1a1714;
    --pf-text-secondary: #5c5548;
    --pf-text-muted: #8a8276;
    --pf-background: #fffbf5;
    --pf-border: rgba(0, 0, 0, 0.06);
    --pf-border-focus: rgba(200, 136, 16, 0.35);
    --pf-skeleton: #f5ede0;
    --pf-primary: #c88810;
    --pf-radius: 12px;
  }
</style>
