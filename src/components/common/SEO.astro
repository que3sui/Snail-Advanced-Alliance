---
export interface Props {
  title: string;
  description?: string;
  image?: string;
  lang?: "zh" | "en";
}

const {
  title,
  description = "蜗壳进阶联盟 — 中国科学技术大学学生组织，打破信息壁垒，构建全周期成长支持体系。",
  image = "/og-default.png",
  lang = "zh",
} = Astro.props;

const siteUrl = "https://advancedguide.cn";
const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
---

<!-- Primary Meta -->
<title>{title} — 蜗壳进阶联盟</title>
<meta name="description" content={description} />
<meta
  name="viewport"
  content="width=device-width, initial-scale=1.0, viewport-fit=cover"
/>
<link rel="canonical" href={canonicalURL} />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={`${siteUrl}${image}`} />
<meta property="og:site_name" content="蜗壳进阶联盟" />
<meta property="og:locale" content={lang === "zh" ? "zh_CN" : "en_US"} />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={`${siteUrl}${image}`} />

<!-- Icons -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />

<!-- Alternates -->
<link
  rel="alternate"
  href={`${siteUrl}/feed.xml`}
  type="application/rss+xml"
  title="蜗壳进阶联盟 RSS"
/>
{
  lang === "zh" ? (
    <link
      rel="alternate"
      hreflang="en"
      href={`${siteUrl}/en${Astro.url.pathname}`}
    />
  ) : (
    <link
      rel="alternate"
      hreflang="zh"
      href={siteUrl + Astro.url.pathname.replace(/^\/en/, "")}
    />
  )
}
