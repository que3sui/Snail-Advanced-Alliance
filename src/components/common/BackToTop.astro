<button
  id="back-to-top"
  class="bg-primary-500 hover:bg-primary-400 pointer-events-none fixed right-8 bottom-8 z-40 flex h-12 w-12 items-center justify-center rounded-full text-white opacity-0 shadow-lg transition-all duration-300 hover:-translate-y-0.5"
  aria-label="Back to top"
>
  <svg
    width="20"
    height="20"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2.5"
  >
    <path d="M18 15l-6-6-6 6"></path>
  </svg>
</button>

<script>
  const btn = document.getElementById("back-to-top")!;
  window.addEventListener("scroll", () => {
    if (window.scrollY > 500) {
      btn.classList.remove("opacity-0", "pointer-events-none");
      btn.classList.add("opacity-100");
    } else {
      btn.classList.add("opacity-0", "pointer-events-none");
      btn.classList.remove("opacity-100");
    }
  });
  btn.addEventListener("click", () => {
    window.scrollTo({ top: 0, behavior: "smooth" });
  });
</script>
