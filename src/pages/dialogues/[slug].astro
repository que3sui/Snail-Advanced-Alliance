---
import BaseLayout from "@/components/layout/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const dialogues = await getCollection("dialogues");
  return dialogues.map((dialogue) => ({ params: { slug: dialogue.id } }));
}

const lang = Astro.url.pathname.startsWith("/en") ? "en" : "zh";

const { slug } = Astro.params;
const dialogues = await getCollection("dialogues");
const dialogue = dialogues.find((d) => d.id === slug);

if (!dialogue) {
  return Astro.redirect("/404");
}

const { Content } = await render(dialogue);
---

<BaseLayout
  title={dialogue.data.title}
  description={lang === "en" && dialogue.data.summaryEn
    ? dialogue.data.summaryEn
    : dialogue.data.summary}
>
  <article class="pt-32 pb-[var(--section-gap)]">
    <div class="mx-auto max-w-[var(--content-narrow)] px-6">
      <div class="mb-8">
        <div class="mb-4 flex flex-wrap items-center gap-3">
          <span
            class="bg-spectrum-purple/15 text-spectrum-purple rounded-full px-2.5 py-0.5 text-xs font-medium"
          >
            {lang === "en" ? "Dialogue" : "对话"}
          </span>
          {
            dialogue.data.tags?.map((tag) => (
              <span class="text-text-muted bg-gemini-hover/50 rounded-full px-2 py-0.5 text-xs">
                {tag}
              </span>
            ))
          }
        </div>
        <h1 class="text-3xl font-bold tracking-tight md:text-4xl">
          {dialogue.data.title}
        </h1>
        <div class="mt-4 flex flex-wrap items-center gap-4 text-sm">
          <span class="text-accent font-medium">
            {dialogue.data.interviewee}
          </span>
          <span class="text-text-secondary">
            {
              lang === "en" && dialogue.data.intervieweeTitleEn
                ? dialogue.data.intervieweeTitleEn
                : dialogue.data.intervieweeTitle
            }
          </span>
          <span class="text-text-muted">
            {
              dialogue.data.date.toLocaleDateString(
                lang === "en" ? "en-US" : "zh-CN",
                { year: "numeric", month: "long", day: "numeric" },
              )
            }
          </span>
          {
            dialogue.data.wordCount && (
              <span class="text-text-muted">
                {dialogue.data.wordCount.toLocaleString()} 字
              </span>
            )
          }
        </div>
      </div>

      <div class="prose prose max-w-none">
        <Content />
      </div>

      {
        dialogue.data.links && dialogue.data.links.length > 0 && (
          <div class="glass mt-12 rounded-2xl p-6">
            <h3 class="mb-3 text-lg font-semibold">
              {lang === "en" ? "Related Links" : "相关链接"}
            </h3>
            <ul class="space-y-2">
              {dialogue.data.links.map((link) => (
                <li>
                  <a
                    href={link.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-accent hover:underline"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )
      }
    </div>
  </article>
</BaseLayout>
