---
import BaseLayout from "@/components/layout/BaseLayout.astro";
import { getCollection } from "astro:content";

const lang = Astro.url.pathname.startsWith("/en") ? "en" : "zh";

const dialogues = await getCollection("dialogues");
dialogues.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout
  title={lang === "en" ? "Dialogues" : "对话"}
  description={lang === "en"
    ? "In-depth interviews with notable USTC alumni"
    : "深度访谈，追溯科大杰出校友的成长轨迹"}
>
  <section class="bg-gemini-surface pt-32 pb-16">
    <div class="mx-auto max-w-[var(--content-max)] px-6 text-center">
      <h1 class="text-text-primary text-4xl font-bold md:text-5xl">
        {lang === "en" ? "Dialogues" : "对话"}
      </h1>
      <p class="text-text-secondary mt-4 text-lg">
        {
          lang === "en"
            ? "Long-form interviews tracing the growth trajectories of USTC alumni"
            : "深度访谈专栏，追溯科大杰出校友的成长轨迹与关键抉择"
        }
      </p>
    </div>
  </section>

  <section class="py-[var(--section-gap)]">
    <div class="mx-auto max-w-[var(--content-max)] px-6">
      <div class="grid gap-6 md:grid-cols-2">
        {
          dialogues.map((dialogue) => {
            const href =
              lang === "en"
                ? `/en/dialogues/${dialogue.id}`
                : `/dialogues/${dialogue.id}`;
            return (
              <a
                href={href}
                class="glass glass-hover group flex flex-col rounded-2xl p-8"
              >
                <div class="mb-4 flex items-center gap-3">
                  <span class="bg-spectrum-purple/15 text-spectrum-purple rounded-full px-2.5 py-0.5 text-xs font-medium">
                    {lang === "en" ? "Dialogue" : "对话"}
                  </span>
                  {dialogue.data.tags?.map((tag) => (
                    <span class="text-text-muted bg-gemini-hover/50 rounded-full px-2 py-0.5 text-xs">
                      {tag}
                    </span>
                  ))}
                </div>
                <h3 class="text-text-primary group-hover:text-accent mb-2 text-xl font-semibold transition-colors">
                  {dialogue.data.title}
                </h3>
                <p class="text-accent mb-4 text-sm">
                  {dialogue.data.interviewee}
                  {lang === "en" && dialogue.data.intervieweeTitleEn
                    ? ` — ${dialogue.data.intervieweeTitleEn}`
                    : ` — ${dialogue.data.intervieweeTitle}`}
                </p>
                <p class="text-text-secondary grow text-sm leading-relaxed">
                  {lang === "en" && dialogue.data.summaryEn
                    ? dialogue.data.summaryEn
                    : dialogue.data.summary}
                </p>
                <div class="text-text-muted mt-4 flex items-center gap-4 text-xs">
                  <span>
                    {dialogue.data.date.toLocaleDateString(
                      lang === "en" ? "en-US" : "zh-CN",
                      { year: "numeric", month: "long", day: "numeric" },
                    )}
                  </span>
                  {dialogue.data.wordCount && (
                    <span>{dialogue.data.wordCount.toLocaleString()} 字</span>
                  )}
                </div>
              </a>
            );
          })
        }
      </div>
    </div>
  </section>
</BaseLayout>
