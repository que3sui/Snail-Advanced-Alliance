---
import BaseLayout from "@/components/layout/BaseLayout.astro";
import { getCollection } from "astro:content";

const lang = Astro.url.pathname.startsWith("/en") ? "en" : "zh";

const events = await getCollection(
  "events",
  ({ data }) => data.series === "talks",
);
events.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout
  title={lang === "en" ? "Alumni Talks" : "蜗壳有约"}
  description={lang === "en"
    ? "USTC Alumni Return Salon Series"
    : "USTC 校友返校沙龙系列"}
>
  <section class="bg-primary-900 pt-32 pb-20">
    <div class="mx-auto max-w-[var(--content-max)] px-6 text-center">
      <h1 class="text-4xl font-extrabold text-white md:text-5xl">
        {lang === "en" ? "Alumni Talks" : "蜗壳有约"}
      </h1>
      <p class="text-primary-200 mt-4 text-lg">
        {
          lang === "en"
            ? "USTC's first alumni return salon series"
            : "USTC 首个校友返校沙龙系列"
        }
      </p>
    </div>
  </section>

  <section class="py-[var(--section-gap)]">
    <div class="mx-auto max-w-[var(--content-max)] px-6">
      <div class="grid gap-6 md:grid-cols-2">
        {
          events.map((event) => {
            const href =
              lang === "en" ? `/en/events/${event.id}` : `/events/${event.id}`;
            return (
              <a
                href={href}
                class="group flex gap-6 rounded-2xl border border-slate-200 bg-white p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg"
              >
                <div class="bg-primary-500/10 text-primary-500 flex h-16 w-16 shrink-0 items-center justify-center rounded-xl">
                  <span class="text-lg font-bold">
                    #{event.id.split("-")[1]}
                  </span>
                </div>
                <div>
                  <span class="text-text-muted text-xs">
                    {event.data.date.toLocaleDateString(
                      lang === "en" ? "en-US" : "zh-CN",
                      {
                        year: "numeric",
                        month: "long",
                        day: "numeric",
                      },
                    )}
                  </span>
                  <h3 class="text-text-primary group-hover:text-primary-600 mt-1 text-lg font-bold transition-colors">
                    {event.data.title}
                  </h3>
                  {event.data.guest && (
                    <p class="text-primary-500 mt-1 text-sm">
                      {event.data.guest} · {event.data.guestTitle}
                    </p>
                  )}
                  <p class="text-text-secondary mt-2 text-sm leading-relaxed">
                    {lang === "en" && event.data.summaryEn
                      ? event.data.summaryEn
                      : event.data.summary}
                  </p>
                </div>
              </a>
            );
          })
        }
      </div>
    </div>
  </section>
</BaseLayout>
