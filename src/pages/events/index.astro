---
import BaseLayout from "@/components/layout/BaseLayout.astro";
import { getCollection } from "astro:content";

const lang = Astro.url.pathname.startsWith("/en") ? "en" : "zh";

const events = await getCollection("events");
events.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const typeLabels: Record<string, { zh: string; en: string }> = {
  talk: { zh: "蜗壳有约", en: "Alumni Talk" },
  hackathon: { zh: "黑客松", en: "Hackathon" },
  workshop: { zh: "工作坊", en: "Workshop" },
  camp: { zh: "蜗壳进阶营", en: "Advancement Camp" },
  visit: { zh: "企业参访", en: "Company Visit" },
  other: { zh: "其他", en: "Other" },
};
---

<BaseLayout
  title={lang === "en" ? "Events" : "活动"}
  description={lang === "en"
    ? "All activities organized by Wokojinjie Alliance"
    : "蜗壳进阶联盟举办的所有活动"}
>
  <section class="bg-primary-900 pt-32 pb-20">
    <div class="mx-auto max-w-[var(--content-max)] px-6 text-center">
      <h1 class="text-4xl font-extrabold text-white md:text-5xl">
        {lang === "en" ? "Events" : "全部活动"}
      </h1>
      <p class="text-primary-200 mt-4 text-lg">
        {
          lang === "en"
            ? "Talks, hackathons, workshops, and more"
            : "沙龙、黑客松、工作坊……精彩活动回顾"
        }
      </p>
    </div>
  </section>

  <section class="py-[var(--section-gap)]">
    <div class="mx-auto max-w-[var(--content-max)] px-6">
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {
          events.map((event) => {
            const href =
              lang === "en" ? `/en/events/${event.id}` : `/events/${event.id}`;
            const typeLabel = typeLabels[event.data.type] ?? typeLabels.other;
            return (
              <a
                href={href}
                class="group block rounded-2xl border border-slate-200 bg-white p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg"
              >
                <div class="mb-3 flex items-center gap-3">
                  <span class="bg-primary-100 text-primary-700 rounded-full px-2.5 py-0.5 text-xs font-medium">
                    {lang === "en" ? typeLabel.en : typeLabel.zh}
                  </span>
                  <span class="text-text-muted text-xs">
                    {event.data.date.toLocaleDateString(
                      lang === "en" ? "en-US" : "zh-CN",
                      {
                        year: "numeric",
                        month: "long",
                        day: "numeric",
                      },
                    )}
                  </span>
                </div>
                <h3 class="text-text-primary group-hover:text-primary-600 mb-2 text-lg font-bold transition-colors">
                  {event.data.title}
                </h3>
                {event.data.guest && (
                  <p class="text-primary-500 text-sm">
                    {event.data.guest} · {event.data.guestTitle}
                  </p>
                )}
                <p class="text-text-secondary mt-2 text-sm leading-relaxed">
                  {lang === "en" && event.data.summaryEn
                    ? event.data.summaryEn
                    : event.data.summary}
                </p>
              </a>
            );
          })
        }
      </div>
    </div>
  </section>
</BaseLayout>
