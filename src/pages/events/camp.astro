---
import BaseLayout from "@/components/layout/BaseLayout.astro";
import { getCollection } from "astro:content";

const lang = Astro.url.pathname.startsWith("/en") ? "en" : "zh";

const events = await getCollection(
  "events",
  ({ data }) => data.series === "camp",
);
events.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout
  title={lang === "en" ? "Advancement Camp" : "蜗壳进阶营"}
  description={lang === "en"
    ? "Research interviews and career planning courses"
    : "科研访谈 + 生涯规划系列课"}
>
  <section class="bg-gemini-surface pt-32 pb-16">
    <div class="mx-auto max-w-[var(--content-max)] px-6 text-center">
      <h1 class="text-text-primary text-4xl font-bold md:text-5xl">
        {lang === "en" ? "Advancement Camp" : "蜗壳进阶营"}
      </h1>
      <p class="text-text-secondary mt-4 text-lg">
        {
          lang === "en"
            ? "In-depth interviews with young AI scholars and career planning courses"
            : "AI 青年学者深度访谈 + 三轨生涯规划课程体系"
        }
      </p>
    </div>
  </section>

  <section class="py-[var(--section-gap)]">
    <div class="mx-auto max-w-[var(--content-max)] px-6">
      <!-- Interview Series -->
      <h2 class="mb-6 text-2xl font-bold">
        {lang === "en" ? "Interview Series" : "访谈系列"}
      </h2>
      <div class="grid gap-6 md:grid-cols-2">
        {
          events.map((event) => {
            const href =
              lang === "en" ? `/en/events/${event.id}` : `/events/${event.id}`;
            return (
              <a
                href={href}
                class="glass glass-hover group flex gap-6 rounded-2xl p-6"
              >
                <div class="bg-spectrum-teal/15 text-spectrum-teal flex h-16 w-16 shrink-0 items-center justify-center rounded-xl">
                  <svg
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                  >
                    <path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                  </svg>
                </div>
                <div>
                  <span class="text-text-muted text-xs">
                    {event.data.date.toLocaleDateString(
                      lang === "en" ? "en-US" : "zh-CN",
                      {
                        year: "numeric",
                        month: "long",
                        day: "numeric",
                      },
                    )}
                  </span>
                  <h3 class="text-text-primary group-hover:text-accent mt-1 text-lg font-bold transition-colors">
                    {event.data.title}
                  </h3>
                  {event.data.guest && (
                    <p class="text-accent mt-1 text-sm">
                      {event.data.guest} · {event.data.guestTitle}
                    </p>
                  )}
                  <p class="text-text-secondary mt-2 text-sm leading-relaxed">
                    {lang === "en" && event.data.summaryEn
                      ? event.data.summaryEn
                      : event.data.summary}
                  </p>
                </div>
              </a>
            );
          })
        }
      </div>
    </div>
  </section>
</BaseLayout>
