---
import BaseLayout from "@/components/layout/BaseLayout.astro";

const lang = Astro.url.pathname.startsWith("/en") ? "en" : "zh";
---

<BaseLayout
  title={lang === "en" ? "Search" : "搜索"}
  description={lang === "en"
    ? "Search content across the site"
    : "搜索全站内容"}
>
  <section class="bg-gemini-surface pt-32 pb-16">
    <div class="mx-auto max-w-[var(--content-narrow)] px-6 text-center">
      <h1 class="text-text-primary text-4xl font-bold md:text-5xl">
        {lang === "en" ? "Search" : "搜索"}
      </h1>
    </div>
  </section>

  <section class="py-[var(--section-gap)]">
    <div class="mx-auto max-w-2xl px-6">
      <div class="pagefind-search-inline">
        <pagefind-input
          placeholder={lang === "en"
            ? "Type to search..."
            : "输入关键词搜索..."}></pagefind-input>
        <pagefind-summary></pagefind-summary>
        <pagefind-results show-images="false"></pagefind-results>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .pagefind-search-inline {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* Style the Pagefind input to match site aesthetic */
  pagefind-input::part(input) {
    border-radius: 12px;
    border: 1px solid var(--pf-border, rgba(0, 0, 0, 0.06));
    background: var(--pf-background, #fffbf5);
    padding: 14px 18px;
    font-size: 1rem;
    font-family: inherit;
    transition:
      border-color 0.3s ease,
      box-shadow 0.3s ease;
  }

  pagefind-input::part(input):focus {
    border-color: var(--pf-border-focus, rgba(200, 136, 16, 0.35));
    box-shadow: 0 0 0 3px rgba(200, 136, 16, 0.08);
    outline: none;
  }
</style>
