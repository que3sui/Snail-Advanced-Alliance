---
import BaseLayout from "@/components/layout/BaseLayout.astro";
import ScrollReveal from "@/components/common/ScrollReveal.astro";
---

<BaseLayout
  title="Advancement Guide"
  description="The Big Data School Undergraduate Advancement Guide"
>
  <section class="bg-primary-900 pt-32 pb-20">
    <div class="mx-auto max-w-[var(--content-narrow)] px-6 text-center">
      <h1 class="text-4xl font-extrabold text-white md:text-5xl">
        Advancement Guide
      </h1>
      <p class="text-primary-200 mt-4 text-lg">
        The first departmental "survival handbook" at USTC
      </p>
    </div>
  </section>

  <section class="py-[var(--section-gap)]">
    <div class="mx-auto max-w-[var(--content-narrow)] px-6">
      <ScrollReveal>
        <h2 class="mb-6 text-2xl font-bold">About the Guide</h2>
        <div class="text-text-secondary space-y-4 leading-relaxed">
          <p>
            The <strong>Big Data School Undergraduate Advancement Guide</strong> is
            the first departmental "survival handbook" at USTC, compiled by the Wokojinjie
            Alliance team.
          </p>
          <p>
            With <strong>100+ articles</strong>, it covers course selection,
            internships, graduate school applications, study abroad, research,
            and career paths.
          </p>
        </div>
      </ScrollReveal>

      <ScrollReveal class="mt-10">
        <a
          href="https://advancedguideforsds.gitbook.io/advancedguide/"
          target="_blank"
          rel="noopener noreferrer"
          class="bg-primary-500 hover:bg-primary-400 inline-flex items-center gap-2 rounded-lg px-8 py-4 font-semibold text-white transition-all hover:shadow-lg"
        >
          Read on GitBook
        </a>
      </ScrollReveal>
    </div>
  </section>
</BaseLayout>
